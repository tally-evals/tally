{
  "name": "@tally-evals/hrpo",
  "version": "0.0.0",
  "private": true,
  "description": "Optimization loop for agents under evaluation on fixed trajectory sets",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "repository": {
    "type": "git",
    "url": "https://github.com/tally-evals/tally.git",
    "directory": "packages/optimiser"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun run tsdown",
    "dev": "bun run tsdown --watch",
    "test": "bun test",
    "lint": "bun run biome check . --config-path ../biome-config/biome.json",
    "lint:fix": "bun run biome check --write . --config-path ../biome-config/biome.json",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "@tally-evals/tally": "workspace:*",
    "@tally-evals/trajectories": "workspace:*"
  },
  "devDependencies": {
    "@tally-evals/core": "workspace:*",
    "@tally-evals/biome-config": "workspace:*",
    "@tally-evals/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "24.6.2",
    "tsdown": "^0.20.0-beta.3",
    "typescript": "^5.3.3"
  }
}
