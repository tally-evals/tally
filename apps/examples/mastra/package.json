{
  "name": "@tally-evals/examples-mastra",
  "version": "1.0.0",
  "private": true,
  "description": "Mastra evaluation examples using the Tally framework",
  "main": "./src/mastra/index.ts",
  "types": "./src/mastra/index.ts",
  "exports": {
    ".": {
      "types": "./src/mastra/index.ts",
      "import": "./src/mastra/index.ts",
      "require": "./src/mastra/index.ts"
    }
  },
  "scripts": {
    "dev": "mastra dev",
    "start": "mastra start",
    "build": "echo 'No build needed for example package'",
    "test": "bun test --timeout 120000",
    "test:watch": "bun test --watch --timeout 120000",
    "cli:build": "bun run --filter @tally-evals/cli build",
    "tui": "bun run cli:build && bunx --no-install tally browse",
    "dev:server": "bun run cli:build && bunx --no-install tally dev server",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@faker-js/faker": "^10.2.0",
    "@mastra/core": "^1.24.1",
    "@mastra/evals": "^1.2.1",
    "@mastra/libsql": "^1.8.0",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.15.0",
    "@mastra/observability": "^1.9.0",
    "@tally-evals/core": "workspace:*",
    "@tally-evals/tally": "workspace:*",
    "@tally-evals/trajectories": "workspace:*",
    "dotenv": "^17.2.3",
    "zod": "^4"
  },
  "devDependencies": {
    "@tally-evals/typescript-config": "workspace:*",
    "@types/node": "^25.0.3",
    "mastra": "^1.5.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.3"
  }
}
